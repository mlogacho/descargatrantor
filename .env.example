# Credenciales CRM Luki (tantror)
CRM_USERNAME=tu_usuario
CRM_PASSWORD=tu_clave

# LukiPlay CMS
CMS_URL=http://lukiplay.com

# Opción A — login automático (recomendado)
CMS_EMAIL=admin@lukiplay.com
CMS_PASSWORD=TuContraseñaCMS

# Opción B — token fijo (expira, no recomendado para producción)
# CMS_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ID del plan de suscripción para usuarios importados del CRM
# Plan: LUKI FULL - Cuando modifiques las características del plan en el CMS,
# los cambios se reflejarán automáticamente en todos los usuarios
SUBSCRIPTION_PLAN_ID=plan-lukiplay
